<?xml version="1.0" encoding="utf-8" ?>
<resources>
	<style name="MainTheme" parent="Maui.MainTheme">
		<item name="colorAccent">#FFB300</item>
		<item name="android:colorAccent">#FFB300</item>
		<item name="colorControlActivated">#FFB300</item>
	</style>

	<style name="Maui.SplashTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
		<item name="android:datePickerDialogTheme">@style/CustomPickerTheme</item>
		<item name="android:timePickerDialogTheme">@style/CustomPickerTheme</item>
	</style>

	<style name="CustomPickerTheme" parent="Theme.AppCompat.Light.Dialog">
		<item name="colorAccent">#FFB300</item>
		<item name="android:textColorPrimary">#090A0F</item>
		<item name="android:textColorSecondary">#4F5664</item>
		<item name="android:textColor">#FFB300</item>
	</style>
</resources>