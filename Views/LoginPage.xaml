<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AutoShift.ViewModels"
             x:Class="AutoShift.Views.LoginPage"
             BackgroundColor="#090A0F"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <viewmodels:LoginViewModel />
    </ContentPage.BindingContext>

    <Grid Padding="30" VerticalOptions="Center">
        <VerticalStackLayout Spacing="30">

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="AUTOSHIFT" TextColor="#FFB300" FontSize="32" FontAttributes="Bold" CharacterSpacing="2" HorizontalOptions="Center"/>
                <Label Text="Inicia sesión para continuar" TextColor="#6C7281" FontSize="14" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Border BackgroundColor="#121622" Stroke="#1E2235" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="20">
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="CORREO ELECTRÓNICO" TextColor="#6C7281" FontSize="10" FontAttributes="Bold"/>
                        <Frame BackgroundColor="#0F111A" BorderColor="#1E2235" CornerRadius="8" Padding="15,0" HasShadow="False" HeightRequest="48">
                            <Entry Placeholder="ejemplo@correo.com" Text="{Binding Email}" TextColor="White" PlaceholderColor="#4F5664" Keyboard="Email" BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="CONTRASEÑA" TextColor="#6C7281" FontSize="10" FontAttributes="Bold"/>
                        <Frame BackgroundColor="#0F111A" BorderColor="#1E2235" CornerRadius="8" Padding="15,0" HasShadow="False" HeightRequest="48">
                            <Entry Placeholder="********" Text="{Binding Password}" TextColor="White" PlaceholderColor="#4F5664" IsPassword="True" BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="20">
                <Button Text="INGRESAR" 
                        Command="{Binding IngresarCommand}" 
                        BackgroundColor="#FFB300" 
                        TextColor="#090A0F" 
                        FontAttributes="Bold" 
                        HeightRequest="50" 
                        CornerRadius="8"/>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#FFB300" HorizontalOptions="Center"/>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="¿No tienes cuenta?" TextColor="#6C7281" VerticalOptions="Center"/>
                    <Label Text="Regístrate" TextColor="#FFB300" FontAttributes="Bold" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrARegistroCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>