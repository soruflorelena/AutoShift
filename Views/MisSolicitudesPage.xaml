<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AutoShift.ViewModels"
             xmlns:models="clr-namespace:AutoShift.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AutoShift.Views.MisSolicitudesPage"
             x:Name="Root"
             x:DataType="viewmodels:MisSolicitudesViewModel"
             BackgroundColor="#090A0F"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" Padding="25,60,25,15" ColumnDefinitions="*, Auto" BackgroundColor="#0F111A">
            <VerticalStackLayout Grid.Column="0">
                <Label Text="HISTORIAL Y ESTADOS" TextColor="#FFB300" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                <Label Text="Mis Solicitudes" TextColor="White" FontSize="30" FontAttributes="Bold"/>
            </VerticalStackLayout>
            <Button Grid.Column="1" 
                    Text="✕" 
                    Command="{Binding Path=BindingContext.VolverCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                    BackgroundColor="#1E2235" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    WidthRequest="40" 
                    HeightRequest="40" 
                    CornerRadius="20" 
                    VerticalOptions="Center" 
                    HorizontalOptions="End"/>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0" Padding="20,15">
            <VerticalStackLayout Spacing="28">

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="ENVIADAS" TextColor="#FFB300" FontSize="14" FontAttributes="Bold" CharacterSpacing="1"/>
                        <BoxView Grid.Column="1" HeightRequest="1" Color="#1E2235" WidthRequest="150" VerticalOptions="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding SolicitudesEnviadas}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No hay solicitudes enviadas." TextColor="#4F5664" HorizontalTextAlignment="Center" Padding="0,15" FontSize="13"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SolicitudServicio">
                                <Border BackgroundColor="#121622" Stroke="#1E2235" StrokeThickness="1" StrokeShape="RoundRectangle 14" Margin="0,0,0,14">
                                    <VerticalStackLayout Padding="18" Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding VehiculoInfo}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                                <Label Text="{Binding TallerNombre}" TextColor="#FFB300" FontSize="12" FontAttributes="Italic"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding IsExpanded, Converter={StaticResource ExpandedToTextConverter}}" TextColor="#6C7281" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" Padding="5"/>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Path=BindingContext.ExpandirSolicitudCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>
                                        </Grid>

                                        <VerticalStackLayout IsVisible="{Binding IsExpanded}" Spacing="12">
                                            <BoxView HeightRequest="1" Color="#1E2235"/>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <Label Text="ESTADO" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Border BackgroundColor="#221C0F" Stroke="#FFB300" StrokeThickness="1" StrokeShape="RoundRectangle 6" Padding="8,4" HorizontalOptions="Start">
                                                        <Label Text="{Binding EstadoTexto}" TextColor="#FFB300" FontSize="11" FontAttributes="Bold"/>
                                                    </Border>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                    <Label Text="DETALLES REQUERIDOS" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding DescripcionProblema}" TextColor="#B2BAC2" FontSize="12" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>


                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="INSPECCIONES DE DIAGNÓSTICO" TextColor="#F59E0B" FontSize="14" FontAttributes="Bold" CharacterSpacing="1"/>
                        <BoxView Grid.Column="1" HeightRequest="1" Color="#1E2235" WidthRequest="80" VerticalOptions="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding SolicitudesInspecciones}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No hay inspecciones pendientes." TextColor="#4F5664" HorizontalTextAlignment="Center" Padding="0,15" FontSize="13"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SolicitudServicio">
                                <Border BackgroundColor="#121622" Stroke="#F59E0B" StrokeThickness="1" StrokeShape="RoundRectangle 14" Margin="0,0,0,14">
                                    <VerticalStackLayout Padding="18" Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding VehiculoInfo}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                                <Label Text="{Binding TallerNombre}" TextColor="#FFB300" FontSize="12"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding IsExpanded, Converter={StaticResource ExpandedToTextConverter}}" TextColor="#6C7281" FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Path=BindingContext.ExpandirSolicitudCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>
                                        </Grid>

                                        <VerticalStackLayout IsVisible="{Binding IsExpanded}" Spacing="12">
                                            <BoxView HeightRequest="1" Color="#1E2235"/>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,0,0,5">
                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <Label Text="ESTADO" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding EstadoTexto}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                    <Label Text="PROBLEMA" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding DescripcionProblema}" TextColor="#B2BAC2" FontSize="12" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                            </Grid>

                                            <Border IsVisible="{Binding EsFechaPropuesta}" BackgroundColor="#1E1A12" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10" Margin="0,4">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="FECHA PROPUESTA POR TALLER:" TextColor="#F59E0B" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding FechaPropuestaTexto}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                            </Border>

                                            <Border IsVisible="{Binding EsFechasPropuestas}" BackgroundColor="#111622" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10" Margin="0,4">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="FECHAS ALTERNATIVAS:" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding FechasAlternativasTexto}" TextColor="White" FontSize="13"/>
                                                </VerticalStackLayout>
                                            </Border>

                                            <Border IsVisible="{Binding EsFechaValidada}" BackgroundColor="#102219" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10" Margin="0,4">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="FECHA CONFIRMADA DE CITA:" TextColor="#22C55E" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding FechaValidadaTexto}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                            </Border>

                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="12" IsVisible="{Binding EsInspeccionSolicitada}" Margin="0,6,0,0">
                                                <Button Text="RECHAZAR" Command="{Binding Path=BindingContext.RechazarInspeccionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"
                                                        BackgroundColor="Transparent" BorderColor="#EF4444" BorderWidth="1.5" TextColor="#EF4444" HeightRequest="40" FontSize="11" FontAttributes="Bold" CornerRadius="8"/>
                                                <Button Grid.Column="1" Text="ACEPTAR INSPECCIÓN" Command="{Binding Path=BindingContext.AceptarInspeccionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"
                                                        BackgroundColor="#FFB300" TextColor="#090A0F" FontAttributes="Bold" HeightRequest="40" FontSize="11" CornerRadius="8"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="12" IsVisible="{Binding EsFechaPropuesta}" Margin="0,6,0,0">
                                                <Button Text="RECHAZAR CITA" Command="{Binding Path=BindingContext.RechazarFechaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"
                                                        BackgroundColor="Transparent" BorderColor="#EF4444" BorderWidth="1.5" TextColor="#EF4444" HeightRequest="40" FontSize="11" FontAttributes="Bold" CornerRadius="8"/>
                                                <Button Grid.Column="1" Text="CONFIRMAR CITA" Command="{Binding Path=BindingContext.AceptarFechaCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"
                                                        BackgroundColor="#22C55E" TextColor="White" FontAttributes="Bold" HeightRequest="40" FontSize="11" CornerRadius="8"/>
                                            </Grid>

                                            <Button Text="PROPONER NUEVAS FECHAS" Command="{Binding Path=BindingContext.ProponerFechasCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"
                                                    BackgroundColor="#3B82F6" TextColor="White" FontAttributes="Bold" HeightRequest="40" FontSize="11" CornerRadius="8" IsVisible="{Binding EsFechaRechazada}" Margin="0,6,0,0"/>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>


                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="ACEPTADAS" TextColor="#3B82F6" FontSize="14" FontAttributes="Bold" CharacterSpacing="1"/>
                        <BoxView Grid.Column="1" HeightRequest="1" Color="#1E2235" WidthRequest="150" VerticalOptions="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding SolicitudesAceptadas}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No hay solicitudes aceptadas." TextColor="#4F5664" HorizontalTextAlignment="Center" Padding="0,15" FontSize="13"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SolicitudServicio">
                                <Border BackgroundColor="#121622" Stroke="#3B82F6" StrokeThickness="1" StrokeShape="RoundRectangle 14" Margin="0,0,0,14">
                                    <VerticalStackLayout Padding="18" Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding VehiculoInfo}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                                <Label Text="{Binding TallerNombre}" TextColor="#FFB300" FontSize="12"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding IsExpanded, Converter={StaticResource ExpandedToTextConverter}}" TextColor="#6C7281" FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Path=BindingContext.ExpandirSolicitudCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>
                                        </Grid>

                                        <VerticalStackLayout IsVisible="{Binding IsExpanded}" Spacing="12">
                                            <BoxView HeightRequest="1" Color="#1E2235"/>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <Label Text="ESTADO" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding EstadoTexto}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                    <Label Text="PROBLEMA" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding DescripcionProblema}" TextColor="#B2BAC2" FontSize="12" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                            </Grid>

                                            <Border IsVisible="{Binding TieneCita}" BackgroundColor="#111622" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="FECHA ASIGNADA DE LA CITA:" TextColor="#3B82F6" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding FechaCitaTexto}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                            </Border>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>


                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="TRABAJOS EN PROCESO" TextColor="#EC4899" FontSize="14" FontAttributes="Bold" CharacterSpacing="1"/>
                        <BoxView Grid.Column="1" HeightRequest="1" Color="#1E2235" WidthRequest="100" VerticalOptions="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding SolicitudesEnProceso}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No hay solicitudes en proceso." TextColor="#4F5664" HorizontalTextAlignment="Center" Padding="0,15" FontSize="13"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SolicitudServicio">
                                <Border BackgroundColor="#121622" Stroke="#EC4899" StrokeThickness="1" StrokeShape="RoundRectangle 14" Margin="0,0,0,14">
                                    <VerticalStackLayout Padding="18" Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding VehiculoInfo}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                                <Label Text="{Binding TallerNombre}" TextColor="#FFB300" FontSize="12"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding IsExpanded, Converter={StaticResource ExpandedToTextConverter}}" TextColor="#6C7281" FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Path=BindingContext.ExpandirSolicitudCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>
                                        </Grid>

                                        <VerticalStackLayout IsVisible="{Binding IsExpanded}" Spacing="12">
                                            <BoxView HeightRequest="1" Color="#1E2235"/>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <Label Text="ESTADO" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding EstadoTexto}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                    <Label Text="PROBLEMA" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding DescripcionProblema}" TextColor="#B2BAC2" FontSize="12" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                            </Grid>

                                            <Border IsVisible="{Binding TieneCita}" BackgroundColor="#111622" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="FECHA DE LA CITA:" TextColor="#EC4899" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding FechaCitaTexto}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                            </Border>

                                            <Button Text="MARCAR COMO COMPLETADO" Command="{Binding Path=BindingContext.MarcarCompletadoCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"
                                                    BackgroundColor="#22C55E" TextColor="White" FontAttributes="Bold" HeightRequest="42" FontSize="11" CornerRadius="8" Margin="0,5,0,0"/>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>


                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="FINALIZADAS" TextColor="#22C55E" FontSize="14" FontAttributes="Bold" CharacterSpacing="1"/>
                        <BoxView Grid.Column="1" HeightRequest="1" Color="#1E2235" WidthRequest="140" VerticalOptions="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding SolicitudesFinalizadas}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No hay solicitudes finalizadas." TextColor="#4F5664" HorizontalTextAlignment="Center" Padding="0,15" FontSize="13"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SolicitudServicio">
                                <Border BackgroundColor="#0F121C" Stroke="#22C55E" StrokeThickness="1" StrokeShape="RoundRectangle 14" Margin="0,0,0,14">
                                    <VerticalStackLayout Padding="18" Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding VehiculoInfo}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                                <Label Text="{Binding TallerNombre}" TextColor="#FFB300" FontSize="12"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding IsExpanded, Converter={StaticResource ExpandedToTextConverter}}" TextColor="#6C7281" FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Path=BindingContext.ExpandirSolicitudCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>
                                        </Grid>

                                        <VerticalStackLayout IsVisible="{Binding IsExpanded}" Spacing="12">
                                            <BoxView HeightRequest="1" Color="#1E2235"/>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <Label Text="ESTADO" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding EstadoTexto}" TextColor="#22C55E" FontSize="13" FontAttributes="Bold"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                    <Label Text="PROBLEMA DETECTADO" TextColor="#6C7281" FontSize="9" FontAttributes="Bold"/>
                                                    <Label Text="{Binding DescripcionProblema}" TextColor="#B2BAC2" FontSize="12" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                            </Grid>

                                            <Border IsVisible="{Binding TieneCotizacion}" BackgroundColor="#07090F" Stroke="#1E2235" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="15" Margin="0,4">
                                                <VerticalStackLayout Spacing="10">
                                                    <Label Text="RESUMEN DE COTIZACIÓN" TextColor="#FFB300" FontSize="10" FontAttributes="Bold" CharacterSpacing="1"/>

                                                    <StackLayout BindableLayout.ItemsSource="{Binding Cotizacion.Detalles}" Spacing="6">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate x:DataType="models:DetalleServicio">
                                                                <Grid ColumnDefinitions="*, Auto">
                                                                    <Label Text="{Binding Nombre}" TextColor="#9EABB8" FontSize="12" />
                                                                    <Label Grid.Column="1" Text="{Binding Precio, StringFormat='${0:N2}'}" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </StackLayout>

                                                    <BoxView HeightRequest="1" Color="#1E2235" Margin="0,4"/>

                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <Label Text="TOTAL PAGADO" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                                                        <Label Grid.Column="1" Text="{Binding Cotizacion.CostoTotal, StringFormat='${0:N2}'}" TextColor="#22C55E" FontSize="18" FontAttributes="Bold"/>
                                                    </Grid>
                                                </VerticalStackLayout>
                                            </Border>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>