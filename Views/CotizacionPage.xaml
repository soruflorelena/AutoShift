<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             xmlns:viewmodels="clr-namespace:AutoShift.ViewModels"
             xmlns:models="clr-namespace:AutoShift.Models"
             x:Class="AutoShift.Views.CotizacionPage"
             x:Name="Root"
             x:DataType="viewmodels:CotizacionViewModel"
             BackgroundColor="#07080A"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0"
                BackgroundColor="#0F1115"
                Padding="25,55,25,20"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,25,25">
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Spacing="5">
                    <Label Text="GESTIÓN DE RESPUESTA"
                           TextColor="#FFC107"
                           FontSize="10"
                           FontAttributes="Bold"
                           CharacterSpacing="2"/>
                    <Label Text="Cotización"
                           TextColor="White"
                           FontSize="26"
                           FontAttributes="Bold"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Spacing="2">
                    <Label Text="TOTAL ESTIMADO"
                           TextColor="#4F5664"
                           FontSize="9"
                           FontAttributes="Bold"
                           HorizontalOptions="End"/>
                    <Label Text="{Binding TotalCotizacion, StringFormat='${0:F2}'}"
                           TextColor="#FFC107"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="End"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="25" Spacing="24">

                <Border BackgroundColor="#16191E"
                        Stroke="#1A1D23"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="DATOS DE LA UNIDAD"
                               TextColor="#4F5664"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1"/>

                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" ColumnSpacing="15" RowSpacing="15">
                            <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="2" Spacing="4">
                                <Label Text="CLIENTE" TextColor="#4F5664" FontSize="9" FontAttributes="Bold"/>
                                <Label Text="{Binding SolicitudSeleccionada.ClienteNombre}" TextColor="White" FontSize="15" FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                                <Label Text="VEHÍCULO" TextColor="#4F5664" FontSize="9" FontAttributes="Bold"/>
                                <Label Text="{Binding SolicitudSeleccionada.VehiculoInfo}" TextColor="#FFC107" FontSize="13" FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                                <Label Text="FECHA" TextColor="#4F5664" FontSize="9" FontAttributes="Bold"/>
                                <Label Text="{Binding SolicitudSeleccionada.Fecha, StringFormat='{0:dd/MM/yyyy}'}" TextColor="White" FontSize="13"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1A1D23" Margin="0,5"/>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="DIAGNÓSTICO DEL CLIENTE" TextColor="#4F5664" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                            <Label Text="{Binding SolicitudSeleccionada.DescripcionProblema}" TextColor="#9EABB8" FontSize="13" LineHeight="1.2"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
                <Border BackgroundColor="#16191E"
                        Stroke="#1A1D23"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">

                        <VerticalStackLayout Spacing="15" IsVisible="{Binding PuedeCotizar}">
                            <Label Text="GENERAR PRESUPUESTO" TextColor="#4F5664" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>

                            <Border BackgroundColor="#0A0C10" Stroke="#1A1D23" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="15,0" HeightRequest="45">
                                <Picker Title="Seleccionar del catálogo..."
                                        ItemsSource="{Binding ServiciosDelTaller}"
                                        ItemDisplayBinding="{Binding Nombre}"
                                        SelectedItem="{Binding ServicioSeleccionado}"
                                        TextColor="White"
                                        TitleColor="#2E333D"
                                        FontSize="14"/>
                            </Border>

                            <Entry Placeholder="O escribir servicio personalizado..."
                                   Text="{Binding NuevoDetalleNombre}"
                                   PlaceholderColor="#2E333D"
                                   TextColor="White"
                                   FontSize="14"
                                   BackgroundColor="#0A0C10"/>

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Entry Placeholder="Precio ($)"
                                       Text="{Binding NuevoDetallePrecio}"
                                       Keyboard="Numeric"
                                       PlaceholderColor="#2E333D"
                                       TextColor="White"
                                       FontSize="14"
                                       BackgroundColor="#0A0C10"/>
                                <Entry Grid.Column="1"
                                       Placeholder="Cantidad"
                                       Text="{Binding NuevoDetalleCantidad}"
                                       Keyboard="Numeric"
                                       PlaceholderColor="#2E333D"
                                       TextColor="White"
                                       FontSize="14"
                                       BackgroundColor="#0A0C10"/>
                            </Grid>

                            <Button Text="AGREGAR AL PRESUPUESTO"
                                    Command="{Binding AgregarDetalleCommand}"
                                    BackgroundColor="#1A1D23"
                                    TextColor="#FFC107"
                                    BorderColor="#FFC107"
                                    BorderWidth="1"
                                    FontAttributes="Bold"
                                    HeightRequest="45"
                                    CornerRadius="8"/>

                            <BoxView HeightRequest="1" Color="#1A1D23" Margin="0,5"/>

                            <Button Text="ENVIAR COTIZACIÓN"
                                    Command="{Binding EnviarCotizacionCommand}"
                                    BackgroundColor="#FFC107"
                                    TextColor="#0A0C10"
                                    FontAttributes="Bold"
                                    HeightRequest="55"
                                    CornerRadius="8"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding SolicitudSeleccionada.EsCotizado}" Spacing="12">
                            <Label Text="ESTADO: COTIZACIÓN ENVIADA" TextColor="#FFC107" FontAttributes="Bold" FontSize="11" CharacterSpacing="1"/>
                            <Label Text="Esperando respuesta del cliente sobre el presupuesto enviado." TextColor="#9EABB8" FontSize="13"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding SolicitudSeleccionada.EsAceptado}" Spacing="15">
                            <Label Text="PROGRAMAR RECEPCIÓN" TextColor="#4F5664" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                            <Label Text="El cliente aceptó. Selecciona fecha y hora para la cita:" TextColor="#9EABB8" FontSize="13"/>

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Border BackgroundColor="#0A0C10" Stroke="#1A1D23" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0" HeightRequest="45">
                                    <DatePicker Date="{Binding FechaCitaSeleccionada}" MinimumDate="{x:Static sys:DateTime.Today}" TextColor="White"/>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="#0A0C10" Stroke="#1A1D23" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0" HeightRequest="45">
                                    <TimePicker Time="{Binding HoraCitaSeleccionada}" TextColor="White"/>
                                </Border>
                            </Grid>

                            <Entry Placeholder="Comentarios adicionales..."
                                   Text="{Binding Comentario}"
                                   PlaceholderColor="#2E333D"
                                   TextColor="White"
                                   FontSize="14"
                                   BackgroundColor="#0A0C10"/>

                            <Button Text="CONFIRMAR CITA"
                                    Command="{Binding AsignarCitaCommand}"
                                    BackgroundColor="#10B981"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    HeightRequest="55"
                                    CornerRadius="8"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding SolicitudSeleccionada.EsCitaAsignada}" Spacing="15">
                            <Label Text="ESTADO: CITA AGENDADA" TextColor="#FFC107" FontAttributes="Bold" FontSize="11" CharacterSpacing="1"/>
                            <Border BackgroundColor="#0A0C10" Padding="15" StrokeShape="RoundRectangle 12">
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                    <Label Text="📅" FontSize="20"/>
                                    <Label Text="{Binding SolicitudSeleccionada.FechaCitaTexto}" TextColor="White" FontSize="14" VerticalOptions="Center" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Button Text="INICIAR TRABAJO (VEHÍCULO RECIBIDO)"
                                    Command="{Binding MarcarEnProcesoCommand}"
                                    BackgroundColor="#FFC107"
                                    TextColor="#0A0C10"
                                    FontAttributes="Bold"
                                    HeightRequest="55"
                                    CornerRadius="8"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding SolicitudSeleccionada.EsEnProceso}" Spacing="15">
                            <Label Text="ESTADO: EN REPARACIÓN" TextColor="#3B82F6" FontAttributes="Bold" FontSize="11" CharacterSpacing="1"/>
                            <Label Text="El vehículo se encuentra actualmente en el área de servicio." TextColor="#9EABB8" FontSize="13"/>
                            <Button Text="MARCAR COMO FINALIZADO"
                                    Command="{Binding MarcarComoCompletadoCommand}"
                                    BackgroundColor="#3B82F6"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    HeightRequest="55"
                                    CornerRadius="8"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding SolicitudSeleccionada.EsFinalizado}" Spacing="15">
                            <Label Text="ESTADO: SERVICIO CONCLUIDO" TextColor="#10B981" FontAttributes="Bold" FontSize="11" CharacterSpacing="1"/>

                            <VerticalStackLayout IsVisible="{Binding SolicitudSeleccionada.TallerCalificado}" Spacing="10">
                                <Label Text="RESEÑA DEL CLIENTE" TextColor="#4F5664" FontSize="9" FontAttributes="Bold"/>
                                <Border BackgroundColor="#0A0C10" Padding="15" StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding SolicitudSeleccionada.MiCalificacion, StringFormat='{0} ★'}" TextColor="#FFC107" FontAttributes="Bold" FontSize="22" HorizontalOptions="Center"/>
                                        <Label Text="{Binding SolicitudSeleccionada.MiComentarioResena}" TextColor="White" FontSize="13" FontAttributes="Italic" HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding SolicitudSeleccionada.EsRechazado}" Spacing="10">
                            <Label Text="ESTADO: RECHAZADO" TextColor="#CC2D2D" FontAttributes="Bold" FontSize="11" CharacterSpacing="1"/>
                            <Label Text="El cliente ha declinado el presupuesto para este servicio." TextColor="#9EABB8" FontSize="13"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="15">
                    <Label Text="CONCEPTOS DEL PRESUPUESTO"
                           TextColor="#4F5664"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="1"/>

                    <CollectionView ItemsSource="{Binding Detalles}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No se han añadido conceptos todavía."
                                   TextColor="#2E333D"
                                   HorizontalOptions="Center"
                                   Margin="0,20"
                                   FontSize="13"/>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:DetalleServicio">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Eliminar"
                                                       BackgroundColor="#CC2D2D"
                                                       Command="{Binding Path=BindingContext.EliminarDetalleCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       CommandParameter="{Binding .}"
                                                       IsVisible="{Binding Path=BindingContext.PuedeCotizar, Source={RelativeSource AncestorType={x:Type ContentPage}}}"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Border BackgroundColor="#111419"
                                            Stroke="#1A1D23"
                                            StrokeThickness="1"
                                            Padding="18"
                                            Margin="0,0,0,12"
                                            StrokeShape="RoundRectangle 12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Nombre}"
                                                       TextColor="White"
                                                       FontAttributes="Bold"
                                                       FontSize="15"/>
                                                <HorizontalStackLayout Spacing="10">
                                                    <Label Text="{Binding Cantidad, StringFormat='Cant: {0}'}"
                                                           TextColor="#4F5664"
                                                           FontSize="11"
                                                           FontAttributes="Bold"/>
                                                    <BoxView WidthRequest="1" HeightRequest="10" Color="#2E333D" VerticalOptions="Center"/>
                                                    <Label Text="{Binding Precio, StringFormat='Unit: ${0:F2}'}"
                                                           TextColor="#4F5664"
                                                           FontSize="11"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Subtotal, StringFormat='${0:F2}'}"
                                                   TextColor="#FFC107"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>