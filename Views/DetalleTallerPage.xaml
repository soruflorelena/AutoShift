<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AutoShift.ViewModels"
             xmlns:models="clr-namespace:AutoShift.Models"
             x:Class="AutoShift.Views.DetalleTallerPage"
             x:DataType="viewmodels:DetalleTallerViewModel"
             BackgroundColor="#0F1115"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" 
                BackgroundColor="#1A1D23" 
                StrokeThickness="0" 
                Padding="20,50,20,25"
                StrokeShape="RoundRectangle 0,0,30,30">
            <VerticalStackLayout Spacing="20">
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="20">
                    <Border Stroke="#FFC107" StrokeThickness="2" StrokeShape="RoundRectangle 20" HeightRequest="90" WidthRequest="90">
                        <Image Source="{Binding TallerSeleccionado.FotoUrl}" Aspect="AspectFill" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding TallerSeleccionado.Nombre}" FontSize="22" FontAttributes="Bold" TextColor="White" />
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="📍" FontSize="12" VerticalOptions="Center"/>
                            <Label Text="{Binding TallerSeleccionado.Ubicacion}" FontSize="13" TextColor="#9BA1AD" />
                        </HorizontalStackLayout>
                        <Border BackgroundColor="#2E333D" HorizontalOptions="Start" Padding="10,2" StrokeShape="RoundRectangle 5">
                            <Label Text="{Binding ServiciosDisponibles.Count, StringFormat='{0} SERVICIOS'}" FontSize="10" FontAttributes="Bold" TextColor="#FFC107" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
                <Label Text="Configure su solicitud seleccionando el vehículo y los servicios requeridos." FontSize="12" TextColor="#4F5664" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="25">

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="VEHÍCULO ASOCIADO" TextColor="#FFC107" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                        <Button Grid.Column="1" Text="ADMINISTRAR" Command="{Binding VerVehiculosCommand}" BackgroundColor="Transparent" TextColor="#F54927" FontSize="10" HeightRequest="25" Padding="0"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding Vehiculos}" 
                                    SelectedItem="{Binding VehiculoSeleccionado}" 
                                    SelectionMode="Single" 
                                    HeightRequest="150">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <!-- AutoShift\Views\DetalleTallerPage.xaml (corrección) -->
                            <DataTemplate x:DataType="models:Vehiculo">
                                <Border x:Name="CardBorder" StrokeThickness="2" StrokeShape="RoundRectangle 15" WidthRequest="180" Padding="15">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter TargetName="CardBorder" Property="Border.Stroke" Value="#2E333D" />
                                                    <Setter TargetName="CardBorder" Property="Border.BackgroundColor" Value="#16191E" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter TargetName="CardBorder" Property="Border.Stroke" Value="#FFC107" />
                                                    <Setter TargetName="CardBorder" Property="Border.BackgroundColor" Value="#242830" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Marca}" TextColor="White" FontAttributes="Bold" FontSize="15"/>
                                        <Label Text="{Binding Modelo}" TextColor="#9BA1AD" FontSize="13"/>
                                        <Label Text="{Binding Placas}" TextColor="#FFC107" FontSize="11" FontAttributes="Bold" Margin="0,5,0,0"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="DETALLES ADICIONALES" TextColor="#FFC107" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                    <Border Stroke="#2E333D" StrokeThickness="1" BackgroundColor="#16191E" StrokeShape="RoundRectangle 12" Padding="10">
                        <Editor Text="{Binding DescripcionCliente}" 
                                Placeholder="Ej: El pedal se siente esponjoso al frenar..."
                                PlaceholderColor="#4F5664"
                                TextColor="White"
                                HeightRequest="100"
                                FontSize="14"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15">
                    <Label Text="CATÁLOGO DE SERVICIOS" TextColor="#FFC107" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                    <CollectionView ItemsSource="{Binding ServiciosDisponibles}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:ServicioSeleccionable">
                                <Border Stroke="#2E333D" StrokeThickness="1" BackgroundColor="#16191E" Margin="0,0,0,10" StrokeShape="RoundRectangle 12" Padding="15">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                                        <CheckBox IsChecked="{Binding IsSelected}" Color="#FFC107" VerticalOptions="Start"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding DatosServicio.Nombre}" FontAttributes="Bold" FontSize="15" TextColor="White" />
                                            <Label Text="{Binding DatosServicio.Descripcion}" FontSize="12" TextColor="#9BA1AD" LineBreakMode="WordWrap" />
                                            <Label Text="{Binding DatosServicio.PrecioBase, StringFormat='Base: ${0:N2}'}" FontSize="12" FontAttributes="Bold" TextColor="#FFC107" Margin="0,5,0,0" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <Border BackgroundColor="#1A1D23" Stroke="#FFC107" StrokeThickness="1" StrokeShape="RoundRectangle 20" Padding="20" Margin="0,10,0,20">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="SUBTOTAL ESTIMADO" TextColor="White" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"/>
                            <Label Grid.Column="1" Text="{Binding Subtotal, StringFormat='${0:N2}'}" TextColor="#FFC107" FontSize="22" FontAttributes="Bold" />
                        </Grid>
                        <Button Text="ENVIAR SOLICITUD" 
                                Command="{Binding EnviarSolicitudCommand}" 
                                BackgroundColor="#FFC107" 
                                TextColor="#0F1115" 
                                FontAttributes="Bold"
                                HeightRequest="55" 
                                CornerRadius="12" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
