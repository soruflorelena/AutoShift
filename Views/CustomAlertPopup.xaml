<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="AutoShift.Views.CustomAlertPopup"
               Color="Transparent">

    <Border BackgroundColor="#121622" Stroke="#1E2235" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="25" WidthRequest="320">
        <VerticalStackLayout Spacing="15">

            <Label x:Name="LblTitulo" Text="Atención" TextColor="#FFB300" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center"/>

            <BoxView HeightRequest="1" Color="#1E2235" Margin="0,5"/>

            <Label x:Name="LblMensaje" Text="Mensaje de error aquí." TextColor="White" FontSize="14" HorizontalTextAlignment="Center" LineBreakMode="WordWrap"/>

            <Button Text="ENTENDIDO" Clicked="OnOkClicked" BackgroundColor="#1E2235" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="45" Margin="0,15,0,0"/>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>