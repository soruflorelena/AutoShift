<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AutoShift.ViewModels"
             xmlns:models="clr-namespace:AutoShift.Models"
             x:Class="AutoShift.Views.DiagnosticoPage"
             x:Name="Root"
             x:DataType="viewmodels:DiagnosticoViewModel"
             BackgroundColor="#0F1115"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" 
                BackgroundColor="#1A1D23" 
                Padding="25,50,25,20" 
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,24,24">

            <VerticalStackLayout Spacing="5">
                <Label Text="ASISTENTE DE MECÁNICA" 
                       TextColor="#FFC107" 
                       FontSize="11" 
                       FontAttributes="Bold" 
                       CharacterSpacing="1"/>
                <Label Text="Diagnóstico del Vehículo" 
                       TextColor="White" 
                       FontSize="24" 
                       FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20" Spacing="25">

                <Border Stroke="#2E333D" StrokeThickness="2" BackgroundColor="#16191E" Padding="15" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="SÍNTOMAS DETECTADOS" 
                               TextColor="#9BA1AD" 
                               FontSize="12" 
                               FontAttributes="Bold"/>

                        <Editor Text="{Binding Sintomas}"
                                Placeholder="Escriba aquí qué fallas nota en su auto..."
                                PlaceholderColor="#4F5664"
                                TextColor="White"
                                HeightRequest="120"
                                FontSize="16"
                                BackgroundColor="#0F1115"/>

                        <Button Text="ANALIZAR FALLAS"
                                Command="{Binding AnalizarSintomasCommand}"
                                BackgroundColor="#FFC107"
                                TextColor="#0F1115"
                                HeightRequest="50"
                                FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="8"/>
                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Spacing="10">
                    <ActivityIndicator IsRunning="True" Color="#FFC107" HeightRequest="20"/>
                    <Label Text="Evaluando componentes..." TextColor="#FFC107" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <VerticalStackLayout IsVisible="{Binding MostrarResultados}" Spacing="20">

                    <CollectionView ItemsSource="{Binding ResultadosMultiples}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:ResultadoIA">
                                <Border BackgroundColor="#1A1D23" 
                                        Stroke="#2E333D" 
                                        StrokeThickness="1" 
                                        Margin="0,0,0,20"
                                        StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout>

                                        <Grid ColumnDefinitions="Auto, *" Padding="15" BackgroundColor="#242830">
                                            <BoxView WidthRequest="4" HeightRequest="20" Color="#FFC107" Margin="0,0,10,0"/>
                                            <Label Grid.Column="1" Text="{Binding Categoria}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                        </Grid>

                                        <Label Text="{Binding Explicacion}" 
                                               TextColor="#CED4DA" 
                                               FontSize="14" 
                                               Padding="15" 
                                               LineHeight="1.3"/>

                                        <BoxView HeightRequest="1" Color="#2E333D" Margin="15,0"/>

                                        <VerticalStackLayout Padding="15" Spacing="10">
                                            <Label Text="TALLERES DISPONIBLES" TextColor="#FFC107" FontSize="11" FontAttributes="Bold"/>

                                            <CollectionView ItemsSource="{Binding TalleresQueLoArreglan}" HeightRequest="100">
                                                <CollectionView.ItemsLayout>
                                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                                                </CollectionView.ItemsLayout>
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:Taller">
                                                        <Border BackgroundColor="#0F1115" Padding="12" WidthRequest="210" StrokeShape="RoundRectangle 8">
                                                            <Grid RowDefinitions="Auto, *">
                                                                <Label Text="{Binding Nombre}" TextColor="White" FontSize="13" FontAttributes="Bold" MaxLines="1"/>
                                                                <Button Grid.Row="1" 
                                                                        Text="SOLICITAR CITA" 
                                                                        FontSize="10"
                                                                        Padding="0"
                                                                        TextColor="#FFC107"
                                                                        BackgroundColor="Transparent"
                                                                        BorderColor="#FFC107"
                                                                        BorderWidth="1"
                                                                        HeightRequest="30"
                                                                        VerticalOptions="End"
                                                                        Command="{Binding Path=BindingContext.SeleccionarTallerCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                                        CommandParameter="{Binding .}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
