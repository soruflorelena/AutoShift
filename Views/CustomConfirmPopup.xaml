<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="AutoShift.Views.CustomConfirmPopup"
               Color="Transparent">

    <Border BackgroundColor="#121622" Stroke="#1E2235" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="25" WidthRequest="320">
        <VerticalStackLayout Spacing="15">

            <Label x:Name="LblTitulo" Text="Confirmar" TextColor="#FFB300" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center"/>

            <BoxView HeightRequest="1" Color="#1E2235" Margin="0,5"/>

            <Label x:Name="LblMensaje" Text="¿Estás seguro?" TextColor="White" FontSize="14" HorizontalTextAlignment="Center" LineBreakMode="WordWrap"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,15,0,0">
                <Button Grid.Column="0" Text="NO" Clicked="OnNoClicked" BackgroundColor="Transparent" BorderColor="#6C7281" BorderWidth="1" TextColor="#6C7281" FontAttributes="Bold" CornerRadius="8" HeightRequest="45"/>
                <Button Grid.Column="1" Text="SÍ" Clicked="OnYesClicked" BackgroundColor="#EF4444" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="45"/>
            </Grid>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>