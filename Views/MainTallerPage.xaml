<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AutoShift.ViewModels"
             xmlns:models="clr-namespace:AutoShift.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AutoShift.Views.MainTallerPage"
             x:Name="Root"
             x:DataType="viewmodels:MainTallerViewModel"
             BackgroundColor="#0B0D0F"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *">

        <Grid Grid.Row="0" BackgroundColor="#111418" Padding="25,45,25,20" ColumnDefinitions="*, Auto">
            <VerticalStackLayout Spacing="2">
                <Label Text="ADMINISTRACIÓN" TextColor="#5B7083" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                <Label Text="Centro de Trabajo" TextColor="#FFFFFF" FontSize="26" FontAttributes="Bold"/>
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="SALIR" Command="{Binding CerrarSesionCommand}"
                    BackgroundColor="#1F242C" TextColor="#E1E8ED" FontSize="12" FontAttributes="Bold"
                    Padding="15,0" HeightRequest="38" CornerRadius="19"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, *, *" Padding="20,15" ColumnSpacing="12" BackgroundColor="#111418">
            <Border BackgroundColor="#181C22" StrokeThickness="1" Stroke="#242C37" Padding="12,15" StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding MostrarSolicitudesNuevasCommand}"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="{Binding NuevasCount}" TextColor="#FFFFFF" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="NUEVAS" TextColor="#FFB01F" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" CharacterSpacing="1"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" BackgroundColor="#181C22" StrokeThickness="1" Stroke="#242C37" Padding="12,15" StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding MostrarSolicitudesEnGestionCommand}"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="{Binding EnCursoCount}" TextColor="#FFFFFF" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="EN GESTIÓN" TextColor="#3B82F6" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" CharacterSpacing="1"/>
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2" BackgroundColor="#181C22" StrokeThickness="1" Stroke="#242C37" Padding="12,15" StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding MostrarSolicitudesFinalizadasCommand}"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="{Binding GananciasMes, StringFormat='${0:N0}'}" TextColor="#10B981" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Label Text="GANANCIA" TextColor="#8899A6" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" CharacterSpacing="1"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <ScrollView Grid.Row="2" Margin="20,15">
            <VerticalStackLayout Spacing="24">

                <VerticalStackLayout Spacing="24">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="ADMINISTRACIÓN DE CATÁLOGO" TextColor="#FFC107" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>

                        <Border BackgroundColor="#16191E"
                                Stroke="#1A1D23"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="20">
                            <VerticalStackLayout Spacing="15">
                                <Label Text="DETALLE DEL SERVICIO"
                                       TextColor="#4F5664"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       CharacterSpacing="1"/>

                                <Grid RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="*, *" ColumnSpacing="10" RowSpacing="10">
                                    <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="2" Spacing="4">
                                        <Entry Placeholder="Nombre del Servicio"
                                               Text="{Binding NuevoNombre}"
                                               PlaceholderColor="#2E333D"
                                               TextColor="White"
                                               FontSize="14"
                                               BackgroundColor="#0A0C10"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                                        <Entry Placeholder="Precio Base ($)"
                                               Text="{Binding NuevoPrecio}"
                                               Keyboard="Numeric"
                                               PlaceholderColor="#2E333D"
                                               TextColor="White"
                                               FontSize="14"
                                               BackgroundColor="#0A0C10"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                                        <Entry Placeholder="Marcas Compatibles"
                                               Text="{Binding NuevasMarcas}"
                                               PlaceholderColor="#2E333D"
                                               TextColor="White"
                                               FontSize="14"
                                               BackgroundColor="#0A0C10"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                                        <Editor Placeholder="Descripción del servicio..."
                                                Text="{Binding NuevaDescripcion}"
                                                AutoSize="TextChanges"
                                                PlaceholderColor="#2E333D"
                                                TextColor="White"
                                                FontSize="14"
                                                BackgroundColor="#0A0C10"
                                                MinimumHeightRequest="80"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="3" Grid.ColumnSpan="2" Spacing="10" Margin="0,10,0,0">
                                        <Button Text="{Binding TextoBotonGuardar}"
                                                Command="{Binding GuardarServicioCommand}"
                                                BackgroundColor="#FFC107"
                                                TextColor="#0A0C10"
                                                FontAttributes="Bold"
                                                HeightRequest="48"
                                                CornerRadius="8"/>

                                        <Button Text="CANCELAR OPERACIÓN"
                                                Command="{Binding CancelarEdicionCommand}"
                                                BackgroundColor="Transparent"
                                                TextColor="#CC2D2D"
                                                BorderColor="#CC2D2D"
                                                BorderWidth="1"
                                                HeightRequest="45"
                                                CornerRadius="8"
                                                IsVisible="{Binding IsEditing}"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="SERVICIOS REGISTRADOS"
                               TextColor="#4F5664"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1"/>

                        <CollectionView ItemsSource="{Binding MisServicios}" SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="No hay servicios registrados todavía." TextColor="#2E333D" HorizontalTextAlignment="Center" Margin="0,20" FontSize="13"/>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Servicio">
                                    <SwipeView>
                                        <SwipeView.RightItems>
                                            <SwipeItems Mode="Reveal">
                                                <SwipeItem Text="Editar" BackgroundColor="#1A1D23"
                                                           Command="{Binding Path=BindingContext.PrepararEdicionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" 
                                                           CommandParameter="{Binding .}" />
                                                <SwipeItem Text="Eliminar" BackgroundColor="#CC2D2D"
                                                           Command="{Binding Path=BindingContext.EliminarServicioCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" 
                                                           CommandParameter="{Binding .}" />
                                            </SwipeItems>
                                        </SwipeView.RightItems>

                                        <Border BackgroundColor="#111419"
                                                Stroke="#1A1D23"
                                                StrokeThickness="1"
                                                Padding="18"
                                                Margin="0,0,0,12"
                                                StrokeShape="RoundRectangle 12">
                                            <Grid RowDefinitions="Auto, Auto" RowSpacing="12">
                                                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                                                    <Label Text="{Binding Nombre}" TextColor="White" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                                                    <Label Grid.Column="1" Text="{Binding PrecioBase, StringFormat='${0:F2}'}" TextColor="#FFC107" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                                                </Grid>

                                                <VerticalStackLayout Grid.Row="1" Spacing="6">
                                                    <Label Text="{Binding Descripcion}" TextColor="#9EABB8" FontSize="13" LineBreakMode="WordWrap" LineHeight="1.2"/>
                                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center" Margin="0,4,0,0">
                                                        <Label Text="COMPATIBILIDAD:" TextColor="#4F5664" FontSize="9" FontAttributes="Bold" VerticalOptions="Center"/>
                                                        <Label Text="{Binding MarcasTexto}" TextColor="#FFC107" FontSize="10" FontAttributes="Bold" VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </SwipeView>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>