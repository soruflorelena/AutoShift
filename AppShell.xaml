<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AutoShift.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AutoShift"
    xmlns:views="clr-namespace:AutoShift.Views"
    Title="AutoShift"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <ShellContent 
        Title="Registro"
        Route="RegistroPage" 
        ContentTemplate="{DataTemplate views:RegistroPage}" />

    <ShellContent 
        Title="Main Cliente"
        Route="MainClientePage" 
        ContentTemplate="{DataTemplate views:MainClientePage}" />
    <ShellContent 
      Title="Main Taller"
      Route="MainTallerPage" 
      ContentTemplate="{DataTemplate views:MainTallerPage}" />

</Shell>
